{
  \"dashboard\": {
    \"id\": null,
    \"title\": \"Generic App Metrics\",
    \"panels\": [
      {
        \"id\": 1,
        \"title\": \"Request Rate\",
        \"type\": \"stat\",
        \"targets\": [{
          \"expr\": \"rate(http_requests_total[5m])\",
          \"legendFormat\": \"req/s\"
        }]
      },
      {
        \"id\": 2,
        \"title\": \"Error Rate\",
        \"type\": \"stat\",
        \"targets\": [{
          \"expr\": \"rate(http_requests_total{status=~\\\"5..\\\"}[5m])\"
        }]
      },
      {
        \"id\": 3,
        \"title\": \"Latency P95\",
        \"type\": \"stat\",
        \"targets\": [{
          \"expr\": \"histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))\"
        }]
      }
    ],
    \"time\": {
      \"from\": \"now-1h\",
      \"to\": \"now\"
    }
  },
  \"overwrite\": true
}
